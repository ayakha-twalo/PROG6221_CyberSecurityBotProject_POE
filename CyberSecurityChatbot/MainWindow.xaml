<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="750"
        Width="750"
        MinHeight="550"
        MinWidth="750"
        Background="#121212">

    <Grid>

        <TabControl Background="#121212"
            BorderThickness="0"
            TabStripPlacement="Left">

            <TabControl.Resources>

                <Style TargetType="TabItem">

                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#1E293B"/>
                    <Setter Property="FontSize" Value="16"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Width" Value="160"/>
                    <Setter Property="Height" Value="70"/>

                </Style>

            </TabControl.Resources>


            <!-- ================================================= -->
            <!-- CHAT TAB -->
            <!-- ================================================= -->

            <TabItem Header="CHAT">

                <Grid Background="#121212">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="160"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->

                    <Border Grid.Row="0"
                            Background="#1E293B"
                            CornerRadius="0,0,15,15"
                            Margin="0,0,0,10">

                        <StackPanel>

                            <TextBlock Text="CYBERSECURITY AWARENESS BOT"
               FontSize="24"
               FontWeight="Bold"
               Foreground="White"
               HorizontalAlignment="Center"
               Margin="10"/>

                            <TextBlock
        Text="╔══════════════╗
║  CYBER BOT   ║
╚══════════════╝"
        FontFamily="Consolas"
        FontSize="16"
        FontWeight="Bold"
        Foreground="#A5D8FF"
        HorizontalAlignment="Center"
        TextAlignment="Center"
        Margin="0,5,0,5"
        xml:space="preserve"/>

                            <TextBlock Text="Your Cybersecurity Assistant"
               Foreground="LightGray"
               FontSize="12"
               HorizontalAlignment="Center"
               Margin="0,5,0,0"/>

                        </StackPanel>

                    </Border>

                    <!-- CHAT AREA -->

                    <Border Grid.Row="1"
                            Margin="10"
                            Background="#1E1E1E"
                            CornerRadius="15">

                        <ScrollViewer x:Name="ChatScrollViewer"
                                      VerticalScrollBarVisibility="Auto">

                            <StackPanel x:Name="ChatPanel"
                                        Margin="10"/>

                        </ScrollViewer>

                    </Border>

                    <!-- INPUT AREA -->

                    <Border Grid.Row="2"
                            Margin="10"
                            CornerRadius="12"
                            Background="#1E1E1E">

                        <Grid Margin="10">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="InputBox"
                                     Grid.Column="0"
                                     Height="42"
                                     Padding="12"
                                     Background="#2D2D30"
                                     Foreground="White"
                                     BorderThickness="0"
                                     FontSize="14"
                                     KeyDown="InputBox_KeyDown"/>

                            <Button Grid.Column="1"
                                    Content="SEND"
                                    Margin="10,0,0,0"
                                    Height="42"
                                    FontWeight="Bold"
                                    Background="#007ACC"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Click="Send_Click"/>

                        </Grid>

                    </Border>

                </Grid>

            </TabItem>

            <!-- ================================================= -->
            <!-- TASKS TAB -->
            <!-- ================================================= -->

            <TabItem Header="TASKS">

                <Grid Background="#121212">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- PAGE HEADER -->

                    <Border Grid.Row="0"
                            Background="#1E293B"
                            CornerRadius="15"
                            Margin="10">

                        <TextBlock Text="TASK MANAGER"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                    </Border>

                    <!-- TASK TITLE -->

                    <TextBox x:Name="TaskTitleBox"
                             Grid.Row="1"
                             Margin="15,5"
                             Height="40"
                             Padding="10"
                             Background="#2D2D30"
                             Foreground="White"
                             BorderThickness="0"
                             Text="Task Title"/>

                    <!-- TASK DESCRIPTION -->

                    <TextBox x:Name="TaskDescriptionBox"
                             Grid.Row="2"
                             Margin="15,5"
                             Height="40"
                             Padding="10"
                             Background="#2D2D30"
                             Foreground="White"
                             BorderThickness="0"
                             Text="Task Description"/>

                    <!-- REMINDER -->

                    <TextBox x:Name="ReminderBox"
                             Grid.Row="3"
                             Margin="15,5"
                             Height="40"
                             Padding="10"
                             Background="#2D2D30"
                             Foreground="White"
                             BorderThickness="0"
                             Text="Reminder (Optional)"/>

                    <!-- TASK LIST -->

                    <Border Grid.Row="4"
                            Margin="15,10"
                            CornerRadius="15"
                            Background="#1E1E1E">

                        <ListBox x:Name="TaskListBox"
                                 Background="#1E1E1E"
                                 Foreground="White"
                                 BorderThickness="0"/>

                    </Border>

                    <!-- BUTTONS -->

                    <StackPanel Grid.Row="5"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="10">

                        <Button x:Name="AddTaskButton"
                                Content="ADD TASK"
                                Width="120"
                                Height="40"
                                Margin="5"
                                Background="#007ACC"
                                Foreground="White"
                                Click="AddTaskButton_Click"/>

                        <Button x:Name="CompleteTaskButton"
                                Content="COMPLETE"
                                Width="120"
                                Height="40"
                                Margin="5"
                                Background="#28A745"
                                Foreground="White"
                                Click="CompleteTaskButton_Click"/>

                        <Button x:Name="DeleteTaskButton"
                                Content="DELETE"
                                Width="120"
                                Height="40"
                                Margin="5"
                                Background="#DC3545"
                                Foreground="White"
                                Click="DeleteTaskButton_Click"/>

                    </StackPanel>

                </Grid>

            </TabItem>

            <!-- ================================================= -->
            <!-- QUIZ TAB -->
            <!-- ================================================= -->

            <TabItem Header="QUIZ">

                <Grid Background="#121212">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->

                    <Border Grid.Row="0"
                            Background="#1E293B"
                            CornerRadius="15"
                            Margin="10">

                        <TextBlock Text="CYBERSECURITY QUIZ"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                    </Border>

                    <!-- QUESTION -->

                    <Border Grid.Row="1"
                            Margin="15,10"
                            CornerRadius="15"
                            Background="#1E1E1E">

                        <TextBlock x:Name="QuizQuestionText"
                                   Margin="15"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextWrapping="Wrap"/>

                    </Border>

                    <!-- OPTIONS -->

                    <StackPanel Grid.Row="2"
                                Margin="20">

                        <RadioButton x:Name="OptionA"
                                     GroupName="QuizOptions"
                                     Foreground="White"
                                     FontSize="15"
                                     Margin="5"/>

                        <RadioButton x:Name="OptionB"
                                     GroupName="QuizOptions"
                                     Foreground="White"
                                     FontSize="15"
                                     Margin="5"/>

                        <RadioButton x:Name="OptionC"
                                     GroupName="QuizOptions"
                                     Foreground="White"
                                     FontSize="15"
                                     Margin="5"/>

                        <RadioButton x:Name="OptionD"
                                     GroupName="QuizOptions"
                                     Foreground="White"
                                     FontSize="15"
                                     Margin="5"/>

                    </StackPanel>

                    <!-- FEEDBACK -->

                    <Border Grid.Row="3"
                            Margin="15"
                            CornerRadius="15"
                            Background="#1E1E1E">

                        <TextBlock x:Name="QuizFeedbackText"
                                   Margin="15"
                                   Foreground="#90EE90"
                                   FontSize="14"
                                   TextWrapping="Wrap"/>

                    </Border>

                    <TextBlock x:Name="QuizProgressText"
                     Grid.Row="4"
                     Margin="15,5"
                     Foreground="LightGray"
                     FontSize="14"
                     HorizontalAlignment="Center"/>

                    <!-- SUBMIT -->

                    <Button x:Name="SubmitAnswerButton"
                            Grid.Row="4"
                            Margin="15,5"
                            Height="42"
                            Background="#007ACC"
                            Foreground="White"
                            FontWeight="Bold"
                            Content="SUBMIT ANSWER"
                            Click="SubmitAnswerButton_Click"/>

                    <!-- NEXT -->

                    <Button x:Name="NextQuestionButton"
                            Grid.Row="5"
                            Margin="15,5,15,15"
                            Height="42"
                            Background="#6C757D"
                            Foreground="White"
                            FontWeight="Bold"
                            Content="NEXT QUESTION"
                            Click="NextQuestionButton_Click"/>

                </Grid>

            </TabItem>

            <!-- ================================================= -->
            <!-- ACTIVITY LOG TAB -->
            <!-- ================================================= -->

            <TabItem Header="ACTIVITY LOG">

                <Grid Background="#121212">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- HEADER -->

                    <Border Grid.Row="0"
                Background="#1E293B"
                CornerRadius="15"
                Margin="10">

                        <TextBlock Text="ACTIVITY LOG"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                    </Border>

                    <!-- LOG DISPLAY -->

                    <Border Grid.Row="1"
                            Margin="15,10"
                            CornerRadius="15"
                            Background="#1E1E1E">

                     <ListBox x:Name="ActivityLogListBox"
                     Background="#1E1E1E"
                     Foreground="White"
                     BorderThickness="0"
                     FontSize="14"
                     Padding="10"/>

                    </Border>

                    <!-- REFRESH BUTTON -->

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="15,5,15,15">

                     <Button Content="REFRESH LOG"
                             Width="150"
                             Height="42"
                             Margin="5"
                             Background="#007ACC"
                             Foreground="White"
                             FontWeight="Bold"
                             BorderThickness="0"
                             Click="RefreshLogButton_Click"/>

                     <Button Content="SHOW ALL"
                             Width="150"
                             Height="42"
                             Margin="5"
                             Background="#28A745"
                             Foreground="White"
                             FontWeight="Bold"
                             BorderThickness="0"
                             Click="ShowAllLogButton_Click"/>
    
                    </StackPanel>


                </Grid>

            </TabItem>

        </TabControl>

    </Grid>

</Window>